# Doxyfile for monitoring-system
# Generated for PlatformIO C++ embedded project

PROJECT_NAME           = "Monitoring System"
PROJECT_BRIEF          = "ESP32 sensor monitoring system (DHT22, BH1750, PIR)"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs/doxygen

# Input
INPUT                  = README.md src include
FILE_PATTERNS          = *.cpp *.h *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
EXCLUDE_PATTERNS       = */.git/* */build/* */.pio/*

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Diagrams (requires dot/graphviz — set to NO if not installed)
HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = NO
QUIET                  = NO
